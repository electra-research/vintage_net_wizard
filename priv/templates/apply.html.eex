<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title><%= ui.title %></title>
    <link rel="stylesheet" type="text/css" href="/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="/css/styles.css">
  </head>
  <body class="h-100 d-flex flex-column">
     <div class="container">
       <div id="logo_container" class="container w-100">
         <a href="/">
           <img class="mt-2 w-100" src="/svg/electra_logo.svg" alt="Electra" />
         </a>
       </div>
       <div id="ssid" value="<%= ssid %>" hidden></div>
       <div id="configuration_status_container" class="container configuration-status-container w-100">
         <div class="row">
           <div class="col-4 text-left">Status</div>
           <div id="configuration_status_value" class="col text-center configuring">Configuring</div>
         </div>
       </div>
       <div class="content text-center">
         <div id="please_wait">
          Please wait while we verify your connection.
         </div>
        <p>If this page doesn't update in 15-30 seconds, check that you're connected to
        the access point named "<b><%= ssid %></b>"</p>
       </div>
       <div id="range_wiregraph_container" class="container apply-page w-100 text-center">
         <img id="wiregraph" class="mt-2 w-100" src="/svg/electra_range_wiregraph.svg" alt="You are all set!" />
         <div>
           <a id="electra_dot_local_button" class="btn btn-primary" target="_blank" href="http://electra.local">Go to electra.local in your browser →</a>
         </div>
       </div>
     </div>
     <footer class="py-3 shadow-sm w-100 text-muted">
       <div class="container">
         <%= for {info_name, info_data} <- device_info do %>
           <div class="row">
             <strong class="col-sm-2"><%= info_name %></strong>
             <span class="col"><%= info_data %></span>
           </div>
         <% end %>
     </footer>
     <script src="/js/apply.js"></script>
     <script>applyConfiguration("<%= ui.title %>", "<%= ui.button_color %>")</script>
  </body>
</html>
